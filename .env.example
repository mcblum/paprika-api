# Paprika credentials
PAPRIKA_EMAIL=you@example.com
PAPRIKA_PASSWORD=yourpassword

# Notion integration
NOTION_TOKEN=secret_...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Database ID of the Stores relation table (the DB that the Store field points at)
NOTION_STORES_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Store name to use when a Paprika list has no match in the Stores database (default: General Grocery)
NOTION_DEFAULT_STORE=General Grocery

# Sync behavior
SYNC_INTERVAL_MS=60000
SYNC_INCLUDE_PURCHASED=false
DRY_RUN=false
LOG_LEVEL=info

# Connector (currently: notion)
CONNECTOR=notion

# Map Paprika list names to Notion Store labels (JSON).
# If a list is not mapped, its Paprika name is used as-is.
# Example: LIST_STORE_MAP={"My Grocery List":"Whole Foods","Costco List":"Costco"}
LIST_STORE_MAP={}
